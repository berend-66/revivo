# Copy this file to `.env` and fill in values. `.env` is gitignored.
# Every var is read via process.env.X — never hardcode secrets in code.

# ─────────────────────────────────────────────────────────────
# LLM — model-agnostic. Switching providers is an env change only;
# no generator code changes. See packages/llm/CLAUDE.md.
# ─────────────────────────────────────────────────────────────

# Provider adapter: openrouter | openai | anthropic
LLM_PROVIDER=openrouter

# API key for the selected provider.
LLM_API_KEY=

# Model slug — MUST match the provider:
#   openrouter → anthropic/claude-sonnet-4.5  (Claude via OpenRouter; mimics native Anthropic)
#                anthropic/claude-opus-4.1     (higher quality, pricier)
#   openai     → gpt-4o
#   anthropic  → claude-sonnet-4-6             (native SDK; enables prompt caching)
LLM_MODEL=anthropic/claude-sonnet-4.5

# Optional: override the API base URL (defaults are set per provider).
# LLM_BASE_URL=

# ─────────────────────────────────────────────────────────────
# Supabase (Stage 2+: the `mockups` table behind mock.revivo.nl)
# Create a project in an EU region; keys are in Project Settings → API.
# The SERVICE-ROLE key is SERVER-SIDE ONLY (bypasses RLS) — never ship it
# to a browser bundle. After setting these, apply the migration:
# see supabase/README.md (dashboard SQL editor, `supabase db push`, or psql).
# Unset → the mock app falls back to local example JSON, and `--push` errors.
# ─────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────────────────
# Google Places (Stage 2 places-mode + Stage 4 sourcing)
# Enable "Places API (New)" on the key. Unset → use --dry-run / --fixture-place.
# ─────────────────────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=
# Optional result/locale bias (defaults shown):
# GOOGLE_PLACES_LANGUAGE=nl
# GOOGLE_PLACES_REGION=NL

# ─────────────────────────────────────────────────────────────
# Instagram-light (Stage 2 places-mode). No scraping — handle + pasted
# bio/captions only. INSTAGRAM_PROVIDER is a SEAM for a future licensed
# 3rd-party API; leave unset (no adapter is implemented yet).
# ─────────────────────────────────────────────────────────────
# INSTAGRAM_PROVIDER=

# ─────────────────────────────────────────────────────────────
# Mock app (apps/mockups → mock.revivo.nl)
# Base URL the generator prints for the shareable mockup link.
# ─────────────────────────────────────────────────────────────
REVIVO_MOCK_BASE_URL=https://mock.revivo.nl
