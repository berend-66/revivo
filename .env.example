# Copy this file to `.env` and fill in values. `.env` is gitignored.
# Every var is read via process.env.X — never hardcode secrets in code.

# ─────────────────────────────────────────────────────────────
# LLM — model-agnostic. Switching providers is an env change only;
# no generator code changes. See packages/llm/CLAUDE.md.
# ─────────────────────────────────────────────────────────────

# Provider adapter: openrouter | openai | anthropic
LLM_PROVIDER=openrouter

# API key for the selected provider.
LLM_API_KEY=

# Model slug — MUST match the provider:
#   openrouter → anthropic/claude-sonnet-4.5  (Claude via OpenRouter; mimics native Anthropic)
#                anthropic/claude-opus-4.1     (higher quality, pricier)
#   openai     → gpt-4o
#   anthropic  → claude-sonnet-4-6             (native SDK; enables prompt caching)
LLM_MODEL=anthropic/claude-sonnet-4.5

# Optional: override the API base URL (defaults are set per provider).
# LLM_BASE_URL=

# ─────────────────────────────────────────────────────────────
# Supabase (Stage 2+ once we move past local-file mockups)
# ─────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────────────────
# Google Places (Stage 2 places-mode + Stage 4 sourcing)
# ─────────────────────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=
