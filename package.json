{
  "name": "revivo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @revivo/marketing dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "gen-mockup": "pnpm -F @revivo/llm gen-mockup",
    "verify-mockup": "pnpm -F @revivo/verify verify",
    "crawl-marketplace": "tsx scripts/crawl-marketplace.ts",
    "generate-pending": "tsx scripts/generate-pending.ts",
    "build-openers": "tsx scripts/build-openers.ts",
    "send-outreach": "tsx scripts/send-outreach.ts",
    "enrich-emails": "tsx scripts/enrich-website-emails.ts"
  },
  "devDependencies": {
    "@revivo/db": "workspace:*",
    "@revivo/llm": "workspace:*",
    "@revivo/shared": "workspace:*",
    "@revivo/sourcing": "workspace:*",
    "@types/node": "^22.19.19",
    "@types/nodemailer": "^8.0.1",
    "dotenv": "^16.4.5",
    "nodemailer": "^9.0.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.2"
  }
}
