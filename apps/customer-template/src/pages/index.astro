---
import { loadConfig } from "~/data/load-config";
import AtelierLayout from "~/variants/atelier/Layout.astro";
import StudioLayout from "~/variants/studio/Layout.astro";
import NeonLayout from "~/variants/neon/Layout.astro";

const config = loadConfig();

const variants = {
  atelier: AtelierLayout,
  studio: StudioLayout,
  neon: NeonLayout,
} as const;

const Variant = variants[config.layout];
---

<Variant config={config} />
