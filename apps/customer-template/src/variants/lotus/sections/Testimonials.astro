---
import type { SiteConfig } from "@revivo/shared";
interface Props { config: SiteConfig }
const { config } = Astro.props;

const list = config.testimonials ?? [];
if (list.length === 0) return;

const stars = (n?: number) => n ? "★".repeat(n) + "☆".repeat(5 - n) : "★★★★★";
---

<section class="lotus-testimonials section" id="reviews">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow">Reviews</span>
      <h2>Wat klanten <em>zeggen</em></h2>
      <span class="gold-rule"></span>
    </div>
    <div class="testimonials-grid">
      {list.map((t) => (
        <div class="testimonial-card reveal">
          <div class="testimonial-stars" aria-label={`${t.rating ?? 5} van 5 sterren`}>
            {stars(t.rating)}
          </div>
          <blockquote class="testimonial-quote">"{t.quote}"</blockquote>
          <div class="testimonial-author">{t.author}</div>
          {t.source && <div class="testimonial-source">{t.source}</div>}
        </div>
      ))}
    </div>
  </div>
</section>
