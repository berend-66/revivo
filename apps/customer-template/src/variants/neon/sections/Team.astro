---
import type { SiteConfig } from "@revivo/shared";
interface Props {
  config: SiteConfig;
}
const { config } = Astro.props;
const team = config.team!;
const rotations = ["rotate-[-2deg]", "rotate-[1.5deg]", "rotate-[-1deg]", "rotate-[2deg]"];
const fmtRating = (r: number) => r.toLocaleString("nl-NL", { minimumFractionDigits: 1, maximumFractionDigits: 1 });
const fmtCount = (n: number) => n.toLocaleString("nl-NL");
---

<section id="team" class="neon-section bg-paper overflow-hidden">
  <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-16">
    <div>
      <span class="neon-label" style="color: var(--color-primary);">— De ploeg</span>
      <h2
        class="font-display text-5xl md:text-7xl font-bold mt-6 text-ink leading-[0.95]"
        style="letter-spacing: -0.03em;"
      >
        Wie je knipt.
      </h2>
    </div>
  </div>

  <div class="grid grid-cols-2 md:grid-cols-3 gap-6 md:gap-8">
    {
      team.map((m, i) => (
        <article class={`${rotations[i % rotations.length]} hover:rotate-0 transition-transform duration-500`}>
          {m.photoUrl ? (
            <div class="overflow-hidden rounded-2xl shadow-md mb-4">
              <img
                src={m.photoUrl}
                alt={m.name}
                loading="lazy"
                class="w-full aspect-[4/5] object-cover hover:scale-105 transition-transform duration-700"
              />
            </div>
          ) : (
            <div
              class="rounded-2xl shadow-md mb-4 aspect-[4/5] flex items-center justify-center font-display font-bold text-6xl text-on-primary"
              style="background-color: var(--color-primary);"
              aria-hidden="true"
            >
              {m.name.charAt(0)}
            </div>
          )}
          <h3 class="font-display text-xl md:text-2xl font-bold text-ink" style="letter-spacing: -0.02em;">
            {m.name}
          </h3>
          {m.role && <p class="neon-label text-ink-soft mt-1">{m.role}</p>}
          {m.specialty && <p class="text-sm text-ink-soft mt-2 leading-snug">{m.specialty}</p>}
          {m.rating != null && (
            <p class="neon-label mt-3 inline-flex items-center gap-1.5 tabular-nums" style="color: var(--color-primary);">
              <span class="font-display text-base font-bold">{fmtRating(m.rating)}★</span>
              {m.reviewCount != null && <span class="text-ink-soft">({fmtCount(m.reviewCount)})</span>}
            </p>
          )}
        </article>
      ))
    }
  </div>
</section>
