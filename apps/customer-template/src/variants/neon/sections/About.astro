---
import type { SiteConfig } from "~/types/site-config";
interface Props {
  config: SiteConfig;
}
const { config } = Astro.props;
---

<section id="about" class="neon-section">
  <div class="grid grid-cols-12 gap-6 items-start">
    <div class="col-span-12 lg:col-span-5">
      <span class="neon-label" style="color: var(--color-primary);">— Studio</span>
      <h2
        class="font-display text-4xl md:text-5xl lg:text-6xl text-ink leading-[1.05] font-semibold mt-6"
        style="letter-spacing: -0.02em;"
      >
        {config.about.heading}
      </h2>
    </div>

    <div class="col-span-12 lg:col-span-7 space-y-5">
      {
        config.about.body.map((p, i) => (
          <p class={i === 0 ? "text-xl md:text-2xl text-ink leading-snug" : "text-base text-ink-soft leading-relaxed"}>
            {p}
          </p>
        ))
      }
    </div>
  </div>

  {
    config.about.stats && (
      <dl class="grid grid-cols-2 md:grid-cols-4 gap-6 mt-20 border-t border-ink/15 pt-12">
        {config.about.stats.map((s) => (
          <div class="flex flex-col">
            <dt class="neon-label text-ink-soft">{s.label}</dt>
            <dd
              class="font-display text-5xl md:text-6xl font-bold mt-3"
              style="color: var(--color-primary); letter-spacing: -0.03em;"
            >
              {s.value}
            </dd>
          </div>
        ))}
      </dl>
    )
  }
</section>
