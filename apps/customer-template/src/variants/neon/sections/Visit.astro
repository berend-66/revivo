---
import type { SiteConfig } from "@revivo/shared";
interface Props {
  config: SiteConfig;
}
const { config } = Astro.props;
// postcode is optional (render-if-present) — never let "undefined" reach the maps query.
const mapQuery = encodeURIComponent(
  `${config.location.address}, ${[config.location.postcode, config.location.city].filter(Boolean).join(" ")}`,
);
const mapSrc = `https://maps.google.com/maps?q=${mapQuery}&t=&z=15&ie=UTF8&iwloc=&output=embed`;
---

<section
  id="visit"
  class="neon-section text-on-primary"
  style="background-color: var(--color-primary-deep);"
>
  <div class="grid grid-cols-12 gap-6">
    <div class="col-span-12 lg:col-span-5">
      <span class="neon-label" style="opacity: 0.75;">— Kom langs</span>
      <h2
        class="font-display text-5xl md:text-7xl font-bold mt-6 leading-[0.95]"
        style="letter-spacing: -0.03em;"
      >
        Bezoek<br />
        de studio.
      </h2>

      <address class="not-italic mt-12 font-display text-2xl md:text-3xl leading-snug">
        {config.location.address}<br />
        {config.location.postcode} {config.location.city}
      </address>

      {
        config.location.transitNotes && (
          <p class="mt-6 text-base opacity-80 max-w-md">{config.location.transitNotes}</p>
        )
      }

      <dl class="mt-12 grid grid-cols-2 gap-x-6 gap-y-3 max-w-md">
        {
          config.hours.map((h) => (
            <div class="contents">
              <dt class="neon-label opacity-80">{h.day}</dt>
              <dd class="font-mono text-sm tabular-nums">
                {h.closed ? "gesloten" : `${h.open}—${h.close}`}
              </dd>
            </div>
          ))
        }
      </dl>
    </div>

    <div class="col-span-12 lg:col-span-7 mt-10 lg:mt-0">
      <div class="rounded-2xl overflow-hidden shadow-2xl">
        <iframe
          src={mapSrc}
          width="100%"
          height="520"
          style="border:0;"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Kaart"
        ></iframe>
      </div>
    </div>
  </div>
</section>
