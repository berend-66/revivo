---
import type { SiteConfig } from "@revivo/shared";
interface Props {
  config: SiteConfig;
}
const { config } = Astro.props;

// NL prices: integers bare (€45), cents always two digits (€67,50 — never €67.5).
// `from` marks a real vanaf-prijs from the listing.
const formatPrice = (item: { price: number | null; from?: boolean }): string => {
  if (item.price === null) return "vanaf —";
  const amount = Number.isInteger(item.price)
    ? String(item.price)
    : item.price.toLocaleString("nl-NL", { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  return `${item.from ? "vanaf " : ""}€${amount}`;
};
---

<section id="services" class="neon-section bg-paper">
  <div class="max-w-7xl">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-16">
      <div>
        <span class="neon-label" style="color: var(--color-primary);">— Wat we doen</span>
        <h2
          class="font-display text-5xl md:text-7xl font-bold mt-6 text-ink leading-[0.95]"
          style="letter-spacing: -0.03em;"
        >
          De prijslijst.
        </h2>
      </div>
      <p class="text-sm text-ink-soft max-w-sm md:text-right">
        Eerlijke prijzen, geen verrassingen. Bij lang of dik haar bespreken we eventuele toeslag vooraf.
      </p>
    </div>

    <div class="space-y-16">
      {
        config.services.map((cat) => (
          <div>
            <div class="flex items-center gap-4 mb-8">
              <h3
                class="font-display text-2xl md:text-3xl font-bold inline-block px-5 py-2.5 rounded-full"
                style="background-color: var(--color-primary); color: var(--color-on-primary);"
              >
                {cat.category}
              </h3>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-1">
              {cat.items.map((item) => (
                <div class="flex items-baseline justify-between gap-4 border-b border-ink/10 py-5">
                  <div class="flex-1">
                    <div class="font-display text-lg md:text-xl text-ink font-medium">{item.name}</div>
                    {item.description && (
                      <p class="text-sm text-ink-soft mt-1">{item.description}</p>
                    )}
                    {item.durationMin && (
                      <span class="neon-label text-ink-soft mt-2 inline-block">{item.durationMin} min</span>
                    )}
                  </div>
                  <span
                    class="font-display text-3xl md:text-4xl font-bold tabular-nums"
                    style="color: var(--color-primary); letter-spacing: -0.02em;"
                  >
                    {formatPrice(item)}
                  </span>
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
