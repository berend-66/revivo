---
import type { SiteConfig } from "@revivo/shared";
interface Props {
  config: SiteConfig;
}
const { config } = Astro.props;

// Sourced phrases only — NO fabricated claims. "Open vandaag" / "Walk-ins
// welkom" were invented (the salon may be closed today / not take walk-ins);
// on a mockup sent to the owner one false line breaks the whole pitch.
const fmtRating = (r: number) => r.toLocaleString("nl-NL", { minimumFractionDigits: 1, maximumFractionDigits: 1 });
const phrases = [
  config.brand.name,
  config.brand.tagline,
  config.location.city,
  config.reputation
    ? `${fmtRating(config.reputation.rating)}★${config.reputation.source ? ` op ${config.reputation.source}` : ""}`
    : null,
  config.about.heading,
].filter((p): p is string => Boolean(p));
const items = [...phrases, ...phrases];
---

<div
  class="overflow-hidden py-6 md:py-8"
  style="background-color: var(--color-primary-vivid); color: var(--color-on-primary);"
>
  <div class="flex whitespace-nowrap neon-marquee-track">
    {
      items.map((p) => (
        <span class="font-display text-3xl md:text-5xl font-medium px-8 inline-flex items-center gap-8">
          <span>{p}</span>
          <span
            class="inline-block w-3 h-3 rotate-45"
            style="background-color: var(--color-accent-vivid);"
            aria-hidden="true"
          />
        </span>
      ))
    }
  </div>
</div>
