---
import type { SiteConfig } from "@revivo/shared";
interface Props {
  config: SiteConfig;
}
const { config } = Astro.props;

const phrases = [
  config.brand.tagline ?? "Studio",
  "Walk-ins welkom",
  config.location.city,
  "Open vandaag",
  config.brand.name,
  config.about.heading,
];
const items = [...phrases, ...phrases];
---

<div
  class="overflow-hidden py-6 md:py-8 border-y"
  style="background-color: var(--color-primary); color: var(--color-on-primary); border-color: var(--color-primary-deep);"
>
  <div class="flex whitespace-nowrap neon-marquee-track">
    {
      items.map((p) => (
        <span class="font-display text-3xl md:text-5xl font-medium px-8 inline-flex items-center gap-8">
          <span>{p}</span>
          <span class="w-2 h-2 rounded-full" style="background-color: var(--color-accent);" />
        </span>
      ))
    }
  </div>
</div>
