---
import type { SiteConfig } from "@revivo/shared";
interface Props {
  config: SiteConfig;
}
const { config } = Astro.props;
const heroImg = config.hero.images[0];
const secondaryImg = config.hero.images[1];

// Brand-color rhythm must fire for ANY headline, not only ones the LLM split
// with "\n". Multi-line → colour the odd lines; single string → colour the
// last word (deterministic, always lands a vivid hit on the first screen).
const raw = config.hero.headline.trim();
const headlineLines = raw.includes("\n") ? raw.split("\n") : null;
const words = raw.split(/\s+/);
const singleLead = words.slice(0, -1).join(" ");
const singleTail = words.length > 1 ? words[words.length - 1] : null;

// Type scales down with headline length so a long line reads as a headline, not
// a hyphenated wall (Unbounded is very wide and the hero is a 7-col column).
const longestLine = headlineLines ? Math.max(...headlineLines.map((l) => l.trim().length)) : raw.length;
const heroMaxRem = longestLine > 26 ? 4.25 : longestLine > 18 ? 5.25 : longestLine > 12 ? 6.5 : 7.5;
---

<section id="top" class="relative overflow-hidden neon-section pt-20 md:pt-28 pb-32 md:pb-40">
  <div class="grid grid-cols-12 gap-4 md:gap-6 items-start">
    <div class="col-span-12 lg:col-span-7">
      <div class="neon-label mb-8 flex items-center gap-3 text-ink-soft">
        <span class="w-3 h-3 rounded-full" style="background-color: var(--color-primary-fill);"></span>
        {config.location.city}
        {config.brand.tagline ? `— ${config.brand.tagline}` : ""}
      </div>

      <h1
        class="neon-hero-headline font-display text-ink font-bold"
        style={`--hero-max: ${heroMaxRem}rem; letter-spacing: -0.03em;`}
      >
        {
          headlineLines ? (
            headlineLines.map((line, i) => (
              <span class="block" style={i % 2 === 1 ? `color: var(--color-primary-vivid);` : ""}>
                {line}
              </span>
            ))
          ) : singleTail ? (
            <span>
              {singleLead}{" "}
              <span style="color: var(--color-primary-vivid);">{singleTail}</span>
            </span>
          ) : (
            <span style="color: var(--color-primary-vivid);">{raw}</span>
          )
        }
      </h1>

      {
        config.hero.subheadline && (
          <p class="text-lg md:text-xl text-ink-soft leading-snug mt-10 max-w-xl">{config.hero.subheadline}</p>
        )
      }

      <div class="mt-12 flex flex-wrap items-center gap-4">
        <a
          href="#booking"
          class="inline-flex items-center gap-3 px-8 py-4 rounded-full text-on-primary font-medium text-base hover:scale-[1.02] transition-transform"
          style="background-color: var(--color-primary-fill);"
        >
          <span>{config.hero.cta?.label ?? "Boek je afspraak"}</span>
          <span class="text-lg" style="color: var(--color-accent-vivid);">→</span>
        </a>
        {
          config.contact.phone && (
            <a
              href={`tel:${config.contact.phone.replace(/\s/g, "")}`}
              class="neon-label text-ink-soft hover:text-ink transition-colors"
            >
              of bel {config.contact.phone}
            </a>
          )
        }
      </div>

      {
        config.reputation && (
          <div class="mt-8 flex items-center gap-3 neon-label text-ink-soft">
            <span class="font-display text-2xl font-bold tabular-nums" style="color: var(--color-primary-on-light);">
              {config.reputation.rating.toLocaleString("nl-NL", { minimumFractionDigits: 1, maximumFractionDigits: 1 })}★
            </span>
            <span>
              {config.reputation.source && `op ${config.reputation.source}`}
              {config.reputation.reviewCount != null &&
                ` · ${config.reputation.reviewCount.toLocaleString("nl-NL")} reviews`}
            </span>
          </div>
        )
      }
    </div>

    <div class="col-span-12 lg:col-span-5 relative mt-10 lg:mt-0 lg:pl-8">
      <figure class="relative">
        <div
          class="absolute inset-0 -z-10 rounded-3xl translate-x-4 translate-y-4"
          style="background-color: var(--color-primary-vivid);"
        >
        </div>
        <img
          src={heroImg}
          alt=""
          class="w-full aspect-[4/5] object-cover rounded-3xl rotate-[-2deg]"
          loading="eager"
        />
      </figure>

      {
        secondaryImg && (
          <figure class="absolute -bottom-16 -left-10 hidden md:block w-44">
            <img
              src={secondaryImg}
              alt=""
              class="w-full aspect-square object-cover rounded-2xl rotate-[6deg] shadow-xl"
              loading="eager"
            />
          </figure>
        )
      }
    </div>
  </div>
</section>

<style>
  /* --hero-max is set per-headline (length-aware) by the component; the clamp
     keeps it fluid and never lets monumental type clip the viewport. hyphens/
     overflow-wrap are a safety net for an unusually long single word. */
  .neon-hero-headline {
    font-size: clamp(2.1rem, 7.5vw, var(--hero-max, 6.25rem));
    line-height: 0.95;
    /* Whole-word wrapping; break only a word that truly can't fit (size is
       already length-aware, so that's rare). No gratuitous auto-hyphenation. */
    overflow-wrap: break-word;
  }
</style>
