---
import type { SiteConfig } from "@revivo/shared";
interface Props {
  config: SiteConfig;
}
const { config } = Astro.props;
const phone = config.contact.phone;
const bookingHref =
  config.booking.externalUrl ?? config.booking.iframeUrl ?? (phone ? `tel:${phone.replace(/\s/g, "")}` : "#");
const bookExternal = /^https?:/.test(bookingHref);
const primaryIsTel = bookingHref.startsWith("tel:");
// Verb must match the action — a "Bel…" label may not ride an online link.
const isCallVerb = config.booking.label ? /^\s*bel\b/i.test(config.booking.label) : false;
const ctaLabel = bookExternal
  ? config.booking.label && !isCallVerb
    ? config.booking.label
    : "Boek online"
  : (config.booking.label ?? (primaryIsTel ? "Bel ons" : "Neem contact op"));
---

<section id="booking" class="neon-section text-center bg-paper">
  <div class="max-w-3xl mx-auto">
    <span class="neon-label" style="color: var(--color-accent-on-light);">— Klaar?</span>

    <h2
      class="font-display text-6xl md:text-8xl lg:text-9xl font-bold mt-6 leading-[0.92] text-ink"
      style="letter-spacing: -0.04em;"
    >
      Boek een stoel.
    </h2>

    <p class="text-lg md:text-xl text-ink-soft mt-8 max-w-xl mx-auto">
      Plan je bezoek aan {config.brand.name} in {config.location.city}.
    </p>

    <div class="mt-12 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href={bookingHref}
        class="inline-flex items-center gap-3 px-10 py-5 rounded-full text-on-primary font-medium text-lg hover:scale-[1.03] transition-transform"
        style="background-color: var(--color-primary-fill);"
        {...bookExternal ? { target: "_blank", rel: "noopener" } : {}}
      >
        <span>{ctaLabel}</span>
        <span class="text-xl" style="color: var(--color-accent-vivid);">→</span>
      </a>

      {
        config.contact.email ? (
          <a
            href={`mailto:${config.contact.email}`}
            class="neon-label px-8 py-5 rounded-full border border-ink/20 text-ink hover:bg-ink hover:text-on-primary transition-colors"
          >
            of mail ons
          </a>
        ) : (
          phone &&
          !primaryIsTel && (
            <a
              href={`tel:${phone.replace(/\s/g, "")}`}
              class="neon-label px-8 py-5 rounded-full border border-ink/20 text-ink hover:bg-ink hover:text-on-primary transition-colors"
            >
              of bel {phone}
            </a>
          )
        )
      }
    </div>
  </div>
</section>
