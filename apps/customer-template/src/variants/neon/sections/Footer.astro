---
import type { SiteConfig } from "@revivo/shared";
interface Props {
  config: SiteConfig;
}
const { config } = Astro.props;
const year = new Date().getFullYear();
const igHandle = config.contact.instagram?.replace(/^@+/, "");
---

<footer class="bg-ink text-on-primary px-6 md:px-8 py-12">
  <div class="grid grid-cols-12 gap-6 items-end max-w-7xl">
    <div class="col-span-12 md:col-span-5">
      <p class="font-display text-3xl font-bold" style="color: var(--color-primary-on-ink);">{config.brand.name}</p>
      {
        config.brand.tagline && (
          <p class="text-sm opacity-70 mt-2 max-w-xs">{config.brand.tagline}</p>
        )
      }
    </div>

    <div class="col-span-6 md:col-span-3">
      <p class="neon-label opacity-60 mb-3">Contact</p>
      <ul class="space-y-1.5 text-sm">
        {config.contact.email && (
          <li><a href={`mailto:${config.contact.email}`} class="hover:underline">{config.contact.email}</a></li>
        )}
        {config.contact.phone && (
          <li><a href={`tel:${config.contact.phone.replace(/\s/g, "")}`} class="hover:underline">{config.contact.phone}</a></li>
        )}
        {igHandle && (
          <li><a href={`https://instagram.com/${igHandle}`} class="hover:underline">@{igHandle}</a></li>
        )}
      </ul>
    </div>

    <div class="col-span-6 md:col-span-4 md:text-right neon-label opacity-60">
      {config.legal.kvk && <div>KvK {config.legal.kvk}</div>}
      {config.legal.btw && <div>BTW {config.legal.btw}</div>}
      <div class="mt-3">© {year} — {config.location.city}</div>
    </div>
  </div>
</footer>
