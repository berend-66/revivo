---
import type { SiteConfig } from "@revivo/shared";
import { studioRail } from "./_rail";
interface Props {
  config: SiteConfig;
}
const { config } = Astro.props;
const rail = studioRail(config);

// NL prices: integers bare (€45), cents always two digits (€67,50 — never €67.5).
// `from` marks a real vanaf-prijs from the listing.
const formatPrice = (item: { price: number | null; from?: boolean }): string => {
  if (item.price === null) return "op aanvraag";
  const amount = Number.isInteger(item.price)
    ? String(item.price)
    : item.price.toLocaleString("nl-NL", { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  return `${item.from ? "vanaf " : ""}€${amount}`;
};
---

<section id="services" class="studio-section border-t rule-strong border-t-1">
  <div class="grid grid-cols-12 gap-4">
    <div class="col-span-12 md:col-span-2 label-mono-mute mb-8 md:mb-0">
      <div><span style="color: var(--color-accent-on-light);">{rail.services}</span> / {rail.total}</div>
      <div class="mt-1">— DIENSTEN</div>
    </div>

    <div class="col-span-12 md:col-span-10">
      <h2 class="font-display-tight text-5xl md:text-7xl text-ink uppercase mb-12 md:mb-16" style="letter-spacing: -0.03em;">
        Diensten<br />
        <span class="text-ink-mute">&amp; tarieven.</span>
      </h2>

      {/* Mobile: each category collapses via a checkbox (first open) so a
          26-item menu is a navigable accordion, not a 3-viewport scroll — pure
          CSS, no JS. Desktop: every body is force-shown (display, which we fully
          control — see studio.css) and flowed into the balanced 3-column grid.
          A checkbox, not <details>, because modern <details> hides content via
          content-visibility, which a CSS display override can't reliably reopen. */}
      <div class="studio-svc">
        {
          config.services.map((cat, i) => (
            <div class="studio-svc-cat">
              <input type="checkbox" id={`svc-${config.slug}-${i}`} class="studio-svc-toggle" checked={i === 0} />
              <label for={`svc-${config.slug}-${i}`} class="studio-svc-summary">
                <h3 class="label-mono inline-block px-2 py-1 bg-ink text-surface">{cat.category}</h3>
              </label>

              <ul class="studio-svc-body font-mono text-sm">
                {cat.items.map((item) => (
                  <li class="border-t rule-soft border-t-1 py-2.5 md:py-3.5 first:border-t-0 first:pt-0">
                    <div class="flex items-baseline justify-between gap-3">
                      <span class="text-ink leading-snug pr-2">{item.name}</span>
                      <span class="text-ink whitespace-nowrap tabular-nums flex items-baseline gap-2">
                        {item.durationMin && <span class="label-mono-mute">{item.durationMin}m</span>}
                        {formatPrice(item)}
                      </span>
                    </div>
                    {item.description && (
                      <p class="text-xs text-ink-mute mt-1.5 leading-relaxed font-sans normal-case tracking-normal">
                        {item.description}
                      </p>
                    )}
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>

      <p class="label-mono-mute mt-10">— Alle prijzen in EUR.</p>
    </div>
  </div>
</section>
