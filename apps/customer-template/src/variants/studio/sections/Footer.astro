---
import type { SiteConfig } from "@revivo/shared";
interface Props {
  config: SiteConfig;
}
const { config } = Astro.props;
const year = new Date().getFullYear();
const igHandle = config.contact.instagram?.replace(/^@+/, "");
---

<footer class="border-t rule-strong border-t-1 px-6 md:px-12 py-10">
  <div class="grid grid-cols-12 gap-4 items-end">
    <div class="col-span-6 md:col-span-3 label-mono font-semibold">
      {config.brand.name}
    </div>

    {(config.legal.kvk || config.legal.btw) && (
      <div class="hidden md:block col-span-3 label-mono-mute">
        {config.legal.kvk && `KvK ${config.legal.kvk}`}
        {config.legal.kvk && config.legal.btw && " / "}
        {config.legal.btw && `BTW ${config.legal.btw}`}
      </div>
    )}

    <div class="hidden md:flex col-span-3 gap-5 label-mono-mute">
      {igHandle && (
        <a href={`https://instagram.com/${igHandle}`} target="_blank" rel="noopener" class="hover:text-ink">
          IG / @{igHandle}
        </a>
      )}
    </div>

    <div class="col-span-6 md:col-span-3 label-mono-mute text-right">
      © {year} — {config.location.city.toUpperCase()}
    </div>
  </div>
</footer>
