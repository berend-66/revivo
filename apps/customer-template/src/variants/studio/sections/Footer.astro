---
import type { SiteConfig } from "~/types/site-config";
interface Props {
  config: SiteConfig;
}
const { config } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="border-t rule-strong border-t-1 px-6 md:px-12 py-10">
  <div class="grid grid-cols-12 gap-4 items-end">
    <div class="col-span-6 md:col-span-3 label-mono font-semibold">
      {config.brand.name}
    </div>

    <div class="hidden md:block col-span-3 label-mono-mute">
      KvK {config.legal.kvk}{config.legal.btw && ` / BTW ${config.legal.btw}`}
    </div>

    <div class="hidden md:flex col-span-3 gap-5 label-mono-mute">
      {config.contact.instagram && (
        <a href={`https://instagram.com/${config.contact.instagram}`} target="_blank" rel="noopener" class="hover:text-ink">
          IG / @{config.contact.instagram}
        </a>
      )}
    </div>

    <div class="col-span-6 md:col-span-3 label-mono-mute text-right">
      © {year} — {config.location.city.toUpperCase()}
    </div>
  </div>
</footer>
