---
import type { SiteConfig } from "@revivo/shared";
interface Props {
  config: SiteConfig;
}
const { config } = Astro.props;
const headlineLines = config.hero.headline.split("\n");
const heroImg = config.hero.images[0];

// Hero type scales DOWN with headline length: a short punchy line stays
// monumental; a long one shrinks so it reads as a headline, not a hyphenated
// wall. (Longest line drives it, since lines stack.)
const longestLine = Math.max(...headlineLines.map((l) => l.trim().length));
const heroMaxRem = longestLine > 26 ? 5 : longestLine > 18 ? 6.5 : longestLine > 12 ? 8.5 : 10.5;

// EST. only when a real 4-digit founding year is present — never "EST. —" or a
// stray non-year stat leaking into the precise-mono rail.
const estYear = config.about.stats
  ?.map((s) => s.value.match(/\b(19|20)\d{2}\b/)?.[0])
  .find((y): y is string => Boolean(y));

// Unified booking action (1 tap to the real channel): hero.cta > online URL > phone.
const phone = config.contact.phone;
const bookHref =
  config.hero.cta?.href ??
  config.booking.externalUrl ??
  config.booking.iframeUrl ??
  (phone ? `tel:${phone.replace(/\s/g, "")}` : "#booking");
const bookExternal = /^https?:/.test(bookHref);
// The verb must match the action: a "Bel…" label may not ride an online-booking
// link (the href is the salon's real bookable listing). Honor a custom non-call
// label; otherwise say what the button actually does.
const customLabel = config.hero.cta?.label ?? config.booking.label;
const isCallVerb = customLabel ? /^\s*bel\b/i.test(customLabel) : false;
const bookLabel = bookExternal
  ? customLabel && !isCallVerb
    ? customLabel
    : "Boek online"
  : (customLabel ?? (bookHref.startsWith("tel:") ? "Bel ons" : "Boek een afspraak"));
---

<section id="top" class="studio-section pt-16 md:pt-20 relative">
  <div class="grid grid-cols-12 gap-4">
    <div class="col-span-12 md:col-span-2 label-mono-mute mb-8 md:mb-0">
      <div><span style="color: var(--color-accent-on-light);">N°01</span></div>
      {estYear && <div class="mt-1">— EST. {estYear}</div>}
      <div class="mt-1">— {config.location.city.toUpperCase()}, NL</div>
      {
        config.reputation && (
          <div class="mt-3 text-ink">
            {config.reputation.rating.toFixed(1).replace(".", ",")}
            <span style="color: var(--color-accent-on-light);">★</span>
            {config.reputation.source && ` ${config.reputation.source.toUpperCase()}`}
            {config.reputation.reviewCount != null && ` · ${config.reputation.reviewCount.toLocaleString("nl-NL")}`}
          </div>
        )
      }
    </div>

    <div class="col-span-12 md:col-span-10">
      <h1
        class="studio-monumental font-display-tight text-ink uppercase"
        style={`--hero-max: ${heroMaxRem}rem; letter-spacing: -0.04em;`}
      >
        {headlineLines.map((line, i) => (
          <span class={`block ${i === 1 ? "pl-[8%] md:pl-[15%]" : ""}`}>{line}</span>
        ))}
      </h1>
    </div>
  </div>

  <div class="grid grid-cols-12 gap-4 mt-16 md:mt-24">
    <div class="col-span-12 md:col-span-5 md:col-start-2">
      {
        config.hero.subheadline && (
          <p class="text-lg md:text-xl text-ink-soft leading-snug max-w-md">{config.hero.subheadline}</p>
        )
      }
      <div class="mt-10 flex items-center gap-4">
        <a
          href={bookHref}
          class="label-mono px-5 py-3 bg-ink text-surface hover:bg-accent transition-colors"
          {...bookExternal ? { target: "_blank", rel: "noopener" } : {}}
        >
          {bookLabel} →
        </a>
        {config.booking.provider !== "custom" && (
          <span class="label-mono-mute">— {config.booking.provider.toUpperCase()}</span>
        )}
      </div>
    </div>

    <figure class="col-span-12 md:col-span-5 md:col-start-8 mt-12 md:mt-0">
      <div class="border rule-strong border-1">
        <img src={heroImg} alt="" class="w-full aspect-[4/5] object-cover grayscale" loading="eager" />
      </div>
      <figcaption class="label-mono-mute mt-2 flex justify-between">
        <span>FIG. 01 — STUDIO</span>
        <span>{config.location.postcode ?? config.location.city}</span>
      </figcaption>
    </figure>
  </div>
</section>
