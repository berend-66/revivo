---
import type { SiteConfig } from "@revivo/shared";
interface Props {
  config: SiteConfig;
}
const { config } = Astro.props;

// The Luxe mosaic defines 8 tile shapes (t1..t8); cycle them over however
// many photos the salon has. Captions (grounded in the photo's actual
// content by the curation step) become the accessible alt text.
const tiles = config.gallery.map((g, i) => ({ ...g, t: `t${(i % 8) + 1}` }));
---

<section class="gallery section" id="gallery">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow">Galerij</span>
      <h2>De <em style="font-style:italic">galerij</em></h2>
    </div>
    <div class="gallery-grid">
      {
        tiles.map((g) => (
          <figure class={`gtile ${g.t} reveal`}>
            <img src={g.url} alt={g.caption ?? ""} title={g.caption} width="600" height="600" loading="lazy" />
          </figure>
        ))
      }
    </div>
  </div>
</section>
