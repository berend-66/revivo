---
import type { SiteConfig } from "@revivo/shared";
interface Props {
  config: SiteConfig;
}
const { config } = Astro.props;

// Wordmark: first word italic when the name has several (the Luxe signature).
const words = config.brand.name.trim().split(/\s+/);
const lead = words.length > 1 ? words[0] : null;
const rest = words.length > 1 ? words.slice(1).join(" ") : config.brand.name;

// Booking CTA: the schema's hero.cta override wins, then a real booking URL,
// then the in-page contact section — never a dead placeholder link.
const bookHref = config.hero.cta?.href ?? config.booking.externalUrl ?? "#contact";
const bookExternal = /^https?:/.test(bookHref);
// Verb must match the action: a "Bel…" label may not ride an online-booking link.
const customLabel = config.hero.cta?.label ?? config.booking.label;
const isCallVerb = customLabel ? /^\s*bel\b/i.test(customLabel) : false;
const bookLabel = bookExternal
  ? customLabel && !isCallVerb
    ? customLabel
    : "Boek online"
  : (customLabel ?? "Maak een afspraak");

const links = [
  { href: "#services", label: "Diensten" },
  { href: "#gallery", label: "Galerij" },
  ...(config.team && config.team.length > 0 ? [{ href: "#team", label: "Team" }] : []),
  ...(config.testimonials && config.testimonials.length > 0 ? [{ href: "#reviews", label: "Reviews" }] : []),
  { href: "#contact", label: "Contact" },
];
---

<nav class="nav" id="nav" aria-label="Hoofdmenu">
  <div class="container nav-inner">
    <button class="hamburger" id="hamburger" aria-label="Menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
    <a href="#top" class="nav-brand">{lead && <em>{lead}</em>}{lead ? ` ${rest}` : rest}</a>
    <div class="nav-links">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
    </div>
    <div class="nav-right">
      <a
        href={bookHref}
        class="btn btn-primary nav-book"
        {...bookExternal ? { target: "_blank", rel: "noopener" } : {}}
      >
        {bookLabel}
      </a>
    </div>
  </div>
</nav>

<div class="mobile-menu" id="mobile-menu">
  {links.map((l) => <a href={l.href}>{l.label}</a>)}
</div>
