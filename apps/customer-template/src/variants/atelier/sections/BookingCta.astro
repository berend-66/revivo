---
import type { SiteConfig } from "@revivo/shared";
interface Props {
  config: SiteConfig;
}
const { config } = Astro.props;

// hero.cta override first, then a real booking URL, then a real phone, then
// the contact section. Never a dead "#book-link".
const bookUrl = config.hero.cta?.href ?? config.booking.externalUrl;
const phone = config.contact.phone;
const href = bookUrl ?? (phone ? `tel:${phone.replace(/[\s()-]/g, "")}` : "#contact");
const external = /^https?:/.test(href);
// Verb must match the action: a "Bel…" label may not ride an online-booking link.
const customLabel = config.hero.cta?.label ?? config.booking.label;
const isCallVerb = customLabel ? /^\s*bel\b/i.test(customLabel) : false;
const label = external
  ? customLabel && !isCallVerb
    ? customLabel
    : "Boek online"
  : (customLabel ?? (phone ? "Bel ons" : "Neem contact op"));
---

<section class="cta section" id="book">
  <svg class="deco-arch" viewBox="0 0 200 140" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true" style="color: var(--bordeaux);">
    <path d="M10 140 V70 a90 90 0 0 1 180 0 V140"></path>
  </svg>
  <div class="container">
    <div class="cta-inner reveal">
      <span class="eyebrow">Boek nu</span>
      <h2>Tijd voor <em style="font-style:italic">jou?</em></h2>
      <p>Plan je bezoek aan {config.brand.name} in {config.location.city}.</p>
      <a href={href} class="btn btn-primary btn-xxl" {...external ? { target: "_blank", rel: "noopener" } : {}}>
        {label}
      </a>
    </div>
  </div>
</section>
