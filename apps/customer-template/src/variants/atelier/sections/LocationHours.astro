---
import type { SiteConfig } from "~/types/site-config";
interface Props {
  config: SiteConfig;
}
const { config } = Astro.props;

const mapQuery = encodeURIComponent(
  `${config.location.address}, ${config.location.postcode} ${config.location.city}`,
);
/* Embed with no API key — works for static pin display. */
const mapSrc = `https://maps.google.com/maps?q=${mapQuery}&t=&z=15&ie=UTF8&iwloc=&output=embed`;
---

<section id="location" class="section-pad bg-surface-deep">
  <div class="grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-16">
    <div class="md:col-span-5">
      <p class="eyebrow-mono mb-6">— Openingstijden</p>
      <h2
        class="font-display text-4xl md:text-5xl text-ink leading-[1.05]"
        style="font-variation-settings: 'opsz' 144, 'SOFT' 60;"
      >
        Wanneer we open zijn.
      </h2>

      <dl class="mt-12 divide-y divide-rule border-y border-rule">
        {
          config.hours.map((h) => (
            <div class="flex items-baseline justify-between py-4">
              <dt class="text-lg text-ink">{h.day}</dt>
              <dd
                class="font-display italic text-lg text-ink-soft"
                style="font-variation-settings: 'opsz' 144, 'SOFT' 80;"
              >
                {h.closed ? "gesloten" : `${h.open} — ${h.close}`}
              </dd>
            </div>
          ))
        }
      </dl>
    </div>

    <div class="md:col-span-7">
      <p class="eyebrow-mono mb-6">— Bezoek ons</p>
      <address class="not-italic">
        <p
          class="font-display text-3xl md:text-4xl text-ink leading-snug"
          style="font-variation-settings: 'opsz' 144, 'SOFT' 60;"
        >
          {config.location.address}<br />
          <span class="text-ink-soft">
            {config.location.postcode} {config.location.city}
          </span>
        </p>

        {
          config.location.transitNotes && (
            <p class="font-display italic text-lg text-ink-mute mt-6 max-w-md">
              {config.location.transitNotes}
            </p>
          )
        }
      </address>

      <div class="mt-10 border border-rule">
        <iframe
          src={mapSrc}
          width="100%"
          height="360"
          style="border:0; filter: grayscale(0.3) sepia(0.15);"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Kaart van de salon"
        ></iframe>
      </div>
    </div>
  </div>
</section>
