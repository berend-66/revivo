---
import type { SiteConfig } from "@revivo/shared";
interface Props {
  config: SiteConfig;
}
const { config } = Astro.props;
const heroImg = config.hero.images[0];
const secondaryImg = config.hero.images[1];
---

<section id="top" class="section-pad pt-20 md:pt-28">
  <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-16 items-start">
    <div class="md:col-span-7">
      <p class="eyebrow-mono mb-8">
        {String(new Date().getFullYear())} — {config.location.city}
      </p>

      <h1
        class="font-display text-5xl sm:text-6xl md:text-7xl lg:text-[5.5rem] leading-[1.02] text-ink"
        style="font-variation-settings: 'opsz' 144, 'SOFT' 60, 'WONK' 0;"
      >
        {config.hero.headline}
      </h1>

      {
        config.hero.subheadline && (
          <p class="font-display italic text-2xl md:text-3xl text-ink-soft leading-snug mt-10 max-w-xl">
            {config.hero.subheadline}
          </p>
        )
      }

      <div class="mt-12 flex flex-wrap items-center gap-6">
        <a
          href="#booking"
          class="inline-flex items-center gap-3 text-ink hover:text-primary transition-colors group"
        >
          <span class="font-display italic text-2xl">{config.hero.cta?.label ?? "Boek je afspraak"}</span>
          <span class="inline-block w-12 h-px bg-current group-hover:w-16 transition-all"></span>
        </a>
        {
          config.brand.tagline && (
            <span class="eyebrow-mono">{config.brand.tagline}</span>
          )
        }
      </div>
    </div>

    <div class="md:col-span-5 md:mt-12">
      <figure class="relative">
        <img
          src={heroImg}
          alt=""
          class="w-full aspect-[4/5] object-cover"
          style="filter: saturate(0.85) contrast(1.05);"
          loading="eager"
        />
        {
          secondaryImg && (
            <img
              src={secondaryImg}
              alt=""
              class="hidden md:block absolute -bottom-16 -left-20 w-44 aspect-[4/5] object-cover border-8 border-surface"
              style="filter: saturate(0.85) contrast(1.05);"
              loading="eager"
            />
          )
        }
      </figure>
    </div>
  </div>
</section>
