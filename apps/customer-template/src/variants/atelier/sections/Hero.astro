---
import type { SiteConfig } from "@revivo/shared";
interface Props {
  config: SiteConfig;
}
const { config } = Astro.props;

// The cinematic hero uses ONE background image; photo curation puts the
// salon's best shot at hero.images[0].
const bg = config.hero.images[0];

// Luxe signature: the last word of the headline in italic serif. Pure
// presentation — the words themselves are the (grounded) LLM headline.
const headlineWords = config.hero.headline.trim().split(/\s+/);
const headlineLead = headlineWords.slice(0, -1).join(" ");
const headlineLast = headlineWords[headlineWords.length - 1];

---

<section class="hero">
  <div class="hero-bg" aria-hidden="true">
    <img src={bg} alt="" width="1600" height="1000" />
  </div>
  <div class="hero-content">
    <h1>
      {headlineWords.length > 1 ? <>{headlineLead}{" "}<em>{headlineLast}</em></> : config.hero.headline}
    </h1>
    {/* Short, always-true signature line — the Luxe style breaks on long
        sentences (0.32em tracked uppercase), so the LLM subheadline stays out
        of the hero; its voice lives in the headline and about-copy. */}
    <p class="hero-sub">
      <span>{config.location.city}</span>
      <span class="dot">·</span>
      <span>{config.location.address}</span>
    </p>
  </div>
  <div class="scroll-cue" aria-hidden="true">
    <svg viewBox="0 0 24 36" fill="none" stroke="currentColor" stroke-width="1">
      <rect x="6" y="2" width="12" height="20" rx="6"></rect>
      <line x1="12" y1="8" x2="12" y2="12"></line>
      <path d="M8 28l4 4 4-4" stroke-linecap="round" stroke-linejoin="round"></path>
    </svg>
  </div>
</section>
