---
import type { SiteConfig } from "@revivo/shared";
interface Props {
  config: SiteConfig;
}
const { config } = Astro.props;

const headingWords = config.about.heading.trim().split(/\s+/);
const headingLead = headingWords.slice(0, -1).join(" ");
const headingLast = headingWords[headingWords.length - 1];

// The hero already shows hero.images[0] full-screen directly above — never
// repeat it as the About portrait. Prefer the curated portrait, then a
// different hero image; with neither, the figure is omitted entirely.
const portrait = config.about.portrait ?? config.hero.images[1];

// about-meta: sourced stats when the brief carried them; otherwise only
// facts we genuinely have (address, reputation). The template's "Sinds 2022"
// slot is NOT defaulted — a founding year we don't know is a fabrication.
const rep = config.reputation;
const rating = rep
  ? rep.rating.toLocaleString("nl-NL", { minimumFractionDigits: 1, maximumFractionDigits: 1 })
  : null;
const meta: Array<{ label: string; value: string }> = config.about.stats?.length
  ? config.about.stats
  : [
      { label: "Locatie", value: config.location.address },
      ...(rep ? [{ label: "Beoordeling", value: `${rating}★` }] : []),
      ...(rep?.reviewCount ? [{ label: "Reviews", value: new Intl.NumberFormat("nl-NL").format(rep.reviewCount) }] : []),
    ];
---

<section class="about section" id="about">
  <div class="container">
    <div class={`about-grid${portrait ? "" : " no-figure"}`}>
      {
        portrait && (
          <div class="about-figure reveal">
            <div class="arch-frame">
              <img src={portrait} alt={config.brand.name} width="900" height="1100" loading="lazy" />
            </div>
          </div>
        )
      }
      <div class="about-text reveal">
        <span class="eyebrow">Welkom</span>
        <h2>
          {
            headingWords.length > 1 ? (
              <>
                {headingLead}{" "}<em style="font-style:italic">{headingLast}</em>
              </>
            ) : (
              config.about.heading
            )
          }
        </h2>
        {config.about.body.map((paragraph) => <p>{paragraph}</p>)}
        {
          meta.length > 0 && (
            <div class="about-meta">
              {meta.map((m) => (
                <div>
                  <span class="caps">{m.label}</span>
                  <strong>{m.value}</strong>
                </div>
              ))}
            </div>
          )
        }
      </div>
    </div>
  </div>
</section>
