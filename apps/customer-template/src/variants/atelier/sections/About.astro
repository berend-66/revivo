---
import type { SiteConfig } from "~/types/site-config";
interface Props {
  config: SiteConfig;
}
const { config } = Astro.props;
---

<section id="about" class="section-pad bg-surface-deep">
  <div class="max-w-6xl">
    <p class="eyebrow-mono mb-6">— Atelier</p>

    <h2
      class="font-display text-4xl md:text-5xl lg:text-6xl leading-[1.05] text-ink max-w-3xl"
      style="font-variation-settings: 'opsz' 144, 'SOFT' 60;"
    >
      {config.about.heading}
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-16 mt-16">
      <div class="md:col-span-7 space-y-5 text-lg leading-relaxed text-ink-soft">
        {config.about.body.map((p, i) => (
          <p class={i === 0 ? "drop-cap" : ""}>{p}</p>
        ))}
      </div>

      {
        config.about.portrait && (
          <figure class="md:col-span-5">
            <img
              src={config.about.portrait}
              alt=""
              class="w-full aspect-[3/4] object-cover"
              style="filter: saturate(0.85) contrast(1.05);"
            />
            {config.brand.tagline && (
              <figcaption class="font-display italic text-base text-ink-mute mt-4 max-w-xs">
                {config.brand.tagline}
              </figcaption>
            )}
          </figure>
        )
      }
    </div>

    {
      config.about.stats && (
        <dl class="grid grid-cols-2 sm:grid-cols-4 gap-8 mt-20 border-t border-rule pt-10">
          {config.about.stats.map((s) => (
            <div>
              <dt class="eyebrow-mono">{s.label}</dt>
              <dd class="font-display text-3xl md:text-4xl text-ink mt-2" style="font-variation-settings: 'opsz' 144, 'SOFT' 40;">
                {s.value}
              </dd>
            </div>
          ))}
        </dl>
      )
    }
  </div>
</section>
