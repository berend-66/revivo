---
import type { SiteConfig } from "@revivo/shared";
interface Props {
  config: SiteConfig;
}
const { config } = Astro.props;

const words = config.brand.name.trim().split(/\s+/);
const lead = words.length > 1 ? words[0] : null;
const rest = words.length > 1 ? words.slice(1).join(" ") : config.brand.name;

const igHandle = config.contact.instagram?.replace(/^@+/, "");
const year = new Date().getFullYear();

const links = [
  { href: "#services", label: "Diensten" },
  { href: "#gallery", label: "Galerij" },
  ...(config.team && config.team.length > 0 ? [{ href: "#team", label: "Team" }] : []),
  ...(config.testimonials && config.testimonials.length > 0 ? [{ href: "#reviews", label: "Reviews" }] : []),
  { href: "#contact", label: "Contact" },
];
---

<footer>
  <div class="container">
    {
      config.brand.logoUrl ? (
        <img class="logo" src={config.brand.logoUrl} alt={config.brand.name} loading="lazy" />
      ) : (
        <p class="footer-wordmark">
          {lead && <em>{lead}</em>}
          {lead ? ` ${rest}` : rest}
        </p>
      )
    }

    <nav class="footer-nav" aria-label="Footer">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>

    {
      igHandle && (
        <div class="footer-social" aria-label="Social media">
          <a href={`https://instagram.com/${igHandle}`} target="_blank" rel="noopener" aria-label="Instagram">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
              <rect x="3" y="3" width="18" height="18" rx="5" />
              <circle cx="12" cy="12" r="4" />
              <circle cx="17.5" cy="6.5" r=".7" fill="currentColor" />
            </svg>
          </a>
        </div>
      )
    }

    <div class="footer-bottom">
      <span>© {year} {config.brand.name}</span>
      {config.legal.kvk && <span>KvK {config.legal.kvk}</span>}
      {config.legal.btw && <span>BTW {config.legal.btw}</span>}
    </div>
  </div>
</footer>
