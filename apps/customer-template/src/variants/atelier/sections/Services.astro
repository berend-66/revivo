---
import type { SiteConfig } from "@revivo/shared";
interface Props {
  config: SiteConfig;
}
const { config } = Astro.props;

// NL prices: integers bare (€45), cents always two digits (€67,50 — never €67,5).
// `from` marks a real vanaf-prijs from the listing; a from-price rendered as a
// flat price misstates the salon's own menu.
const formatPrice = (item: { price: number | null; from?: boolean }): string => {
  if (item.price === null) return "op aanvraag";
  const amount = Number.isInteger(item.price)
    ? String(item.price)
    : item.price.toLocaleString("nl-NL", { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  return `${item.from ? "vanaf " : ""}€${amount}`;
};

const formatDuration = (min?: number): string | null => {
  if (!min) return null;
  if (min < 60) return `${min} min`;
  const h = Math.floor(min / 60);
  const m = min % 60;
  return m === 0 ? `${h} u` : `${h} u ${m}m`;
};

const bookUrl = config.booking.externalUrl;
const categories = config.services;
---

<section class="services section" id="services">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow">Diensten</span>
      <h2>Onze <em style="font-style:italic">diensten</em></h2>
      {config.brand.tagline && <p class="services-sub">{config.brand.tagline}</p>}
    </div>

    {
      categories.length > 1 && (
        <div class="tabs" role="tablist" aria-label="Diensten">
          {categories.map((cat, i) => (
            <button
              class={`tab${i === 0 ? " active" : ""}`}
              role="tab"
              data-tab={String(i)}
              aria-selected={i === 0 ? "true" : "false"}
            >
              {cat.category}
            </button>
          ))}
        </div>
      )
    }

    {
      categories.map((cat, i) => (
        <div
          class={`panel reveal${i === 0 ? " active" : ""}`}
          data-panel={String(i)}
          role="tabpanel"
          aria-label={cat.category}
        >
          {cat.items.map((item) => (
            <div class="treatment">
              <div>
                <div class="treatment-name">{item.name}</div>
                {item.description && <p class="treatment-desc">{item.description}</p>}
              </div>
              <div class="treatment-meta">
                {formatDuration(item.durationMin) && (
                  <span class="treatment-duration">{formatDuration(item.durationMin)}</span>
                )}
                <span class="treatment-price">{formatPrice(item)}</span>
              </div>
            </div>
          ))}
          {bookUrl && (
            <div class="panel-foot">
              <a href={bookUrl} target="_blank" rel="noopener" class="text-link">
                Bekijk alles →
              </a>
              <a href={bookUrl} target="_blank" rel="noopener" class="btn btn-ghost">
                Boek online
              </a>
            </div>
          )}
        </div>
      ))
    }
  </div>
</section>
