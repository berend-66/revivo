---
import type { SiteConfig } from "@revivo/shared";
interface Props {
  config: SiteConfig;
}
const { config } = Astro.props;

// NL prices: integers bare (€45), cents always two digits (€67,50 — never €67,5).
// `from` marks a real vanaf-prijs from the listing; a from-price rendered as a
// flat price misstates the salon's own menu.
const formatPrice = (item: { price: number | null; from?: boolean }): string => {
  if (item.price === null) return "op aanvraag";
  const amount = Number.isInteger(item.price)
    ? String(item.price)
    : item.price.toLocaleString("nl-NL", { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  return `${item.from ? "vanaf " : ""}€${amount}`;
};

const formatDuration = (min?: number): string | null => {
  if (!min) return null;
  if (min < 60) return `${min} min`;
  const h = Math.floor(min / 60);
  const m = min % 60;
  return m === 0 ? `${h} u` : `${h} u ${m}m`;
};
---

<section id="services" class="section-pad">
  <div class="max-w-6xl">
    <p class="eyebrow-mono mb-6">— Wat we doen</p>

    <h2
      class="font-display text-4xl md:text-5xl lg:text-6xl leading-[1.05] text-ink max-w-3xl"
      style="font-variation-settings: 'opsz' 144, 'SOFT' 60;"
    >
      Het werk, en wat het kost.
    </h2>

    <div class="mt-20 space-y-20">
      {
        config.services.map((cat) => (
          <div>
            <div class="flex items-baseline gap-6 mb-8">
              <h3 class="font-display italic text-3xl md:text-4xl text-primary" style="font-variation-settings: 'opsz' 144, 'SOFT' 100, 'WONK' 1;">
                {cat.category}
              </h3>
              <span class="flex-1 h-px bg-rule"></span>
            </div>

            <ul class="space-y-0">
              {cat.items.map((item) => (
                <li class="grid grid-cols-[1fr_auto] gap-x-6 md:gap-x-10 items-baseline py-5 border-b border-rule">
                  <div>
                    <p class="text-lg md:text-xl text-ink">{item.name}</p>
                    {item.description && (
                      <p class="text-sm text-ink-mute mt-1.5 italic max-w-xl">{item.description}</p>
                    )}
                    {formatDuration(item.durationMin) && (
                      <p class="eyebrow-mono mt-2">{formatDuration(item.durationMin)}</p>
                    )}
                  </div>
                  <span
                    class="font-display text-2xl md:text-3xl text-ink italic"
                    style="font-variation-settings: 'opsz' 144, 'SOFT' 80;"
                  >
                    {formatPrice(item)}
                  </span>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <p class="text-sm text-ink-mute mt-16 max-w-2xl italic">
      Prijzen zijn richtprijzen. Bij behandelingen met lang of dik haar rekenen we soms een toeslag — altijd
      vooraf besproken, nooit een verrassing.
    </p>
  </div>
</section>
