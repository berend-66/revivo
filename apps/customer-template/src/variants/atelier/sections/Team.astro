---
import type { SiteConfig, TeamMember } from "@revivo/shared";
interface Props {
  config: SiteConfig;
}
const { config } = Astro.props;

// Lead card: the face of the salon, chosen among photo'd members only (no
// photo → no lead card, never a placeholder portrait). Listing order is NOT
// the signal — the live audit caught a junior stylist crowned over the
// owner at "Salon Dani". Preference: owner role > name in the salon's brand
// name > most-reviewed > first.
const team: TeamMember[] = config.team ?? [];
const photoed = team.filter((m) => m.photoUrl);
const brandTokens = new Set(
  config.brand.name
    .toLowerCase()
    .split(/[^\p{L}]+/u)
    .filter(Boolean),
);
const lead =
  photoed.find((m) => /eigenaar|eigenaresse|owner|oprichter/i.test(m.role ?? "")) ??
  photoed.find((m) =>
    m.name
      .toLowerCase()
      .split(/[^\p{L}]+/u)
      .some((t) => t.length > 1 && brandTokens.has(t)),
  ) ??
  (photoed.length
    ? photoed.reduce((a, b) => ((b.reviewCount ?? 0) > (a.reviewCount ?? 0) ? b : a))
    : undefined);
const roster = team.filter((m) => m !== lead);

const fmtRating = (m: TeamMember): string | null =>
  m.rating
    ? `${m.rating.toLocaleString("nl-NL", { minimumFractionDigits: 1, maximumFractionDigits: 1 })}★${
        m.reviewCount ? ` · ${new Intl.NumberFormat("nl-NL").format(m.reviewCount)} reviews` : ""
      }`
    : null;

const bookUrl = config.booking.externalUrl;
---

<section class="team section" id="team">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow">Het team</span>
      <h2>Ons <em style="font-style:italic">team</em></h2>
    </div>

    <div class={`team-grid${lead ? "" : " roster-only"}`}>
      {
        lead && (
          <div class="lead-card reveal">
            <div class="lead-figure">
              <div class="arch-frame">
                <img src={lead.photoUrl} alt={lead.name} width="900" height="1100" loading="lazy" />
              </div>
            </div>
            <div class="lead-info">
              <h3>{lead.name}</h3>
              {(lead.role || fmtRating(lead)) && <span class="caps">{lead.role ?? fmtRating(lead)}</span>}
              {lead.specialty && <p>{lead.specialty}</p>}
              {bookUrl && (
                <a href={bookUrl} target="_blank" rel="noopener" class="btn btn-ghost">
                  Boek bij {lead.name} →
                </a>
              )}
            </div>
          </div>
        )
      }

      {
        roster.length > 0 && (
          <div class="team-roster reveal">
            {roster.map((m) => (
              <div class="member">
                <div class="member-circle">
                  {m.photoUrl ? (
                    <img src={m.photoUrl} alt={m.name} loading="lazy" />
                  ) : (
                    <span>{m.name.trim().charAt(0).toUpperCase()}</span>
                  )}
                </div>
                <h4>{m.name}</h4>
                {(m.role || fmtRating(m)) && <span class="caps">{m.role ?? fmtRating(m)}</span>}
              </div>
            ))}
          </div>
        )
      }
    </div>
  </div>
</section>
