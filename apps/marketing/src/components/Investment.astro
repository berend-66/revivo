---
import Eyebrow from "./Eyebrow.astro";

const includes = [
  "Volledig op maat ontworpen website",
  "Mobiele versie (responsive)",
  "Koppeling boekingssysteem",
  "Google vindbaar (SEO-basis)",
  "SSL-certificaat & hosting",
  "Één week gratis revisies",
  "Koppeling Google Maps",
  "Overdracht & instructie",
];
---

<section id="investering" class="bg-cream-100 section border-y border-cream-200">
  <div class="max-w-6xl mx-auto px-8 md:px-16">
    <Eyebrow label="Investering" />

    <h2 class="font-display text-4xl md:text-5xl lg:text-6xl leading-[1.1] text-ink-900 mt-8 max-w-3xl">
      Eenmalig. <em class="italic font-normal text-burgundy-800">Geen verrassingen.</em>
    </h2>

    <p class="text-base md:text-lg text-ink-700 leading-relaxed mt-8 max-w-2xl">
      Een vaste prijs voor alles — van eerste gesprek tot oplevering. Inclusief een week
      aanpassingen na lancering, zodat alles precies wordt zoals je het wilt.
    </p>

    <div class="mt-16 flex flex-col md:flex-row md:items-baseline gap-6 md:gap-10">
      <span class="font-display text-7xl md:text-8xl lg:text-[9rem] leading-none text-burgundy-900">€1.000</span>
      <div class="text-xs uppercase tracking-[0.25em] text-ink-500">
        <div>Eenmalig tarief</div>
        <div class="mt-1">Alles inbegrepen</div>
      </div>
    </div>

    <div class="mt-20 border-t border-cream-200 pt-12">
      <p class="font-display italic text-sm text-burgundy-800/80 mb-8">Wat is inbegrepen</p>
      <ul class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-4">
        {
          includes.map((item) => (
            <li class="flex items-start gap-3 text-ink-700">
              <span class="text-burgundy-800 mt-2 text-xs">—</span>
              <span class="text-base">{item}</span>
            </li>
          ))
        }
      </ul>
    </div>

    <figure class="mt-24 max-w-3xl mx-auto text-center">
      <span class="font-display italic text-4xl text-burgundy-800/40 leading-none">"</span>
      <blockquote class="font-display italic text-xl md:text-2xl text-ink-900 leading-relaxed mt-2">
        Een goede website is geen kostenpost.
        <span class="block mt-2">Het is je belangrijkste verkoper — 24 uur per dag.</span>
      </blockquote>
    </figure>
  </div>
</section>
