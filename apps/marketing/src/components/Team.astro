---
import { useTranslations, type Locale } from "~/i18n/ui";
interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);

// Stylized line-art avatars (DiceBear "notionists", CC0) stand in until Nelson +
// Berend supply real portraits — swap the src in public/ to replace.
const team = [
  { name: "Nelson", photo: "/team-nelson.png", desc: t("team.nelson.desc") },
  { name: "Berend", photo: "/team-berend.png", desc: t("team.berend.desc") },
];
---

<section class="team section">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow">{t("team.eyebrow")}</span>
      <h2>Nelson <em>&amp;</em> Berend</h2>
      <p class="team-sub">{t("team.sub")}</p>
    </div>
    <div class="team-grid">
      {
        team.map((member) => (
          <div class="lead-card reveal">
            <div class="lead-figure"><div class="arch-frame"><img src={member.photo} alt={member.name} loading="lazy" /></div></div>
            <div class="lead-info">
              <h3>{member.name}</h3>
              <span class="caps">{t("team.role")}</span>
              <p>{member.desc}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
