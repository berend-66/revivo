---
/**
 * Decorative outlined circles inspired by the proposal PDF.
 * Used as background flourishes inside burgundy sections.
 */
interface Props {
  position?: "top-right" | "bottom-left" | "top-left" | "bottom-right";
  size?: number;
  opacity?: number;
}

const { position = "top-right", size = 480, opacity = 0.18 } = Astro.props;

const positions: Record<string, string> = {
  "top-right": "top: -25%; right: -15%;",
  "bottom-left": "bottom: -25%; left: -15%;",
  "top-left": "top: -25%; left: -15%;",
  "bottom-right": "bottom: -25%; right: -15%;",
};
---

<svg
  aria-hidden="true"
  viewBox="0 0 100 100"
  style={`position: absolute; width: ${size}px; height: ${size}px; opacity: ${opacity}; pointer-events: none; ${positions[position]}`}
>
  <circle cx="50" cy="50" r="49" fill="none" stroke="currentColor" stroke-width="0.4" />
</svg>
