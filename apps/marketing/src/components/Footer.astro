---
const year = new Date().getFullYear();
---

<footer class="bg-burgundy-900 text-cream-100/70 px-8 md:px-16 py-10">
  <div class="max-w-6xl mx-auto flex flex-col sm:flex-row sm:items-end justify-between gap-6">
    <div>
      <div class="font-display italic text-2xl text-cream-50 lowercase">revivo</div>
      <p class="text-xs uppercase tracking-[0.22em] text-cream-100/40 mt-2">
        Websites voor kapsalons & beautysalons
      </p>
    </div>

    <div class="text-xs uppercase tracking-[0.22em] text-cream-100/40 sm:text-right">
      <div>© {year} · revivo</div>
      <div class="mt-1">Amsterdam · NL</div>
    </div>
  </div>
</footer>
