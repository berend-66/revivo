# Supabase — the SAME production project the pipeline writes to (no staging DB).
# The service-role key bypasses RLS, so it is SERVER-SIDE ONLY: never prefix it
# with NEXT_PUBLIC_ and never read it in a Client Component. Set both as Vercel
# project env vars (Project Settings → Environment Variables).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: override the deployed mock host used in opener links + previews.
# Defaults to @revivo/shared DEFAULT_MOCK_BASE_URL (https://revivo-mockups.vercel.app).
REVIVO_MOCK_BASE_URL=

# App-level auth (HTTP Basic via middleware.ts). REQUIRED in production — this
# plan's Vercel Authentication can't gate the production *.vercel.app URL, so
# without ADMIN_PASSWORD set the deployed app is public. Leave unset locally to
# skip the prompt during dev.
ADMIN_USER=revivo
ADMIN_PASSWORD=
