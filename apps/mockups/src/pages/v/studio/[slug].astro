---
/** Per-variant render page — see src/pages/[slug].astro for why each variant has
 * its own page (CSS isolation under SSR). Statically imports ONLY studio. */
import StudioLayout from "~/variants/studio/Layout.astro";
import NotFound from "../../../components/NotFound.astro";
import { resolveForVariant, MOCKUP_CACHE_CONTROL } from "../../../lib/render";

const { slug } = Astro.params;
const config = await resolveForVariant(Astro.locals.mockupConfig, slug, "studio");
if (config) Astro.response.headers.set("Cache-Control", MOCKUP_CACHE_CONTROL);
else Astro.response.status = 404;
---

{config ? <StudioLayout config={config} /> : <NotFound slug={slug} />}
